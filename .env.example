# UNCaGED Dashboard Configuration Example
# Copy this to .env and change the values

# Admin Credentials
DASHBOARD_USER=change-me
DASHBOARD_PASS=change-me-strong-password

# Security
# Generate a random string for SECRET_KEY (e.g., openssl rand -hex 32)
SECRET_KEY=yoursecretkeyhere
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Server Settings
PORT=5000
MAX_UPLOAD_MB=100
CALIBRE_ADD_TIMEOUT_SECONDS=120
